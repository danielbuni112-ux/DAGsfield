{
  "name": "open-higgsfield-ai",
  "description": "Open-source alternative to Higgsfield AI — AI image generation and cinema studio with 20+ models",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "clean": "rm -rf dist",
    "build:packages": "npm run build --workspaces --if-present",
    "dev:packages": "npm run dev --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.24",
    "canvas": "^3.2.3",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "puppeteer": "^24.37.2",
    "tailwindcss": "^4.1.18",
    "terser": "^5.27.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@higgsfield/layout": "file:packages/layout",
    "@higgsfield/navigation": "file:packages/navigation",
    "@higgsfield/tokens": "file:packages/tokens",
    "@supabase/supabase-js": "^2.99.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "dompurify": "^3.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
